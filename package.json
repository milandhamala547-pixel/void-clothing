{
  "name": "void-clothing",
  "version": "1.0.0",
  "description": "VOID - Minimal Wear E-commerce",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "package": "npm run build && node scripts/package-dist.mjs"
  },
  "keywords": [
    "ecommerce",
    "clothing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18"
  }
}
